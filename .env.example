# ====== AWS ======
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=replace
AWS_SECRET_ACCESS_KEY=replace
AWS_SESSION_TOKEN=replace

# ====== Aplicación ======
PORT=8082
APP_ENV=local
EXPEDIENTE=750843

# Tablas DynamoDB.
SALES_TABLE=sales
ITEMS_TABLE=sale_items

# URL base con la que se construyen los enlaces de descarga del PDF.
# En local apunta al puerto del propio servicio; en producción debería
# apuntar al DNS público del EC2.
BASE_URL=http://localhost:8082

# URL del servicio de catálogos. Este módulo lo consulta vía HTTP para
# obtener cliente y producto al crear la venta (Factor IV - Backing services).
CATALOGOS_URL=http://localhost:8081

# URL del servicio de notificaciones. Este módulo le pide enviar el correo
# después de crear la venta.
NOTIFICACIONES_URL=http://localhost:8083

# ====== CloudWatch (observabilidad) ======
# Namespace bajo el cual se publican las métricas.
CW_NAMESPACE=Examen2/750843
# Si lo dejas en "true" las métricas SI se mandan a CloudWatch (cuesta dinero
# en una cuenta real; en AWS Academy es gratis dentro del lab).
# Útil para apagarlas en pruebas locales sin AWS.
CW_ENABLED=true
